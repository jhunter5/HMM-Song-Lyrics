{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "upload-route": {
        "ClusterId": "processing-cluster",
        "Match": {
          "Path": "/upload"
        }
      }
    },
    "Clusters": {
      "processing-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://processing-service:5000/"
          }
        }
      }
    }
  }
}
