{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "upload-route": {
        "ClusterId": "processing-cluster",
        "Match": {
          "Path": "/upload"
        }
      },
      "process-audio-route": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/process-audio"
        }
      }
    },
    "Clusters": {
      "processing-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://processing-service:5000/"
          }
        }
      },
      "music-cluster": {
        "HttpClient": {
          "ActivityTimeout": "00:10:00"
        },
        "Destinations": {
          "destination1": {
            "Address": "http://music-processing-service:5001/"
          }
        }
      }
    }
  }
}
